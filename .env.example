# Copy this file to .env and fill in your own key.
# Keys are read at build time via import.meta.env (Vite).

# Which AI provider to use: "openai" (default) or "local" (no LLM — the sim
# runs purely on its built-in reflex/schedule behavior, no key needed).
VITE_AI_PROVIDER=openai

# Required when VITE_AI_PROVIDER=openai.
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Optional: override the OpenAI model (defaults to gpt-4.1-nano).
# VITE_OPENAI_MODEL=gpt-4.1-nano
